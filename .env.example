APP_NAME="WWT Cargo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_HOME=/admin/home

# Redirect all HTTP traffic to HTTPS (set true on production)
FORCE_HTTPS=false

# Set true on production when using HTTPS (keeps session cookies secure)
SESSION_SECURE_COOKIE=false

# Local default: en | Production default (when APP_LOCALE unset): es
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wwt_cargo
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo (Sendinblue) API — used for registration & notification emails
# Get key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL="${BRAND_SUPPORT_EMAIL}"
BREVO_SENDER_NAME="${BRAND_SHORT_NAME}"

# WWT brand (replaces legacy WWC defaults)
BRAND_NAME="World Wide Trading Group"
BRAND_SHORT_NAME="WWT"
BRAND_EMAIL_SIGNATURE="Best regards, The WWT Team"
BRAND_LOGO_PATH="images/wwt-logo.png"
BRAND_SUPPORT_EMAIL="consultas@wwt.com.py"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
